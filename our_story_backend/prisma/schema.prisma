generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BUYER
  ARTISAN
  ADMIN
}

enum NotificationType {
  NEW_PRODUCT
  ARTISAN_UPDATE
  ORDER_UPDATE
  PROMO
}

enum StoryBlockType {
  paragraph
  image
  process_step
  timeline_item
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  username     String?  @unique
  passwordHash String
  name         String
  avatarUrl    String?
  isVerified   Boolean  @default(false)
  role         Role     @default(BUYER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  artisanProfile  ArtisanProfile?
  follows         Follow[]
  cart            Cart?
  wishlist        Wishlist[]
  notifications   Notification[]
  reviews         Review[]
  helpfulVotes    ReviewHelpfulVote[]
  reviewReports   ReviewReport[]
  sharedEvents    ShareEvent[]
}

model ArtisanProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  user            User     @relation(fields: [userId], references: [id])
  displayName     String?
  shopHandle      String?  @unique
  tagline         String?
  bio             String?
  craft           String
  location        String
  quote           String?
  followerCount   Int      @default(0)
  totalReviews    Int      @default(0)
  averageRating   Decimal  @default(0.0) @db.Decimal(3, 2)
  totalCrafts     Int      @default(0)
  isVerified      Boolean  @default(false)
  coverImageUrl   String?
  bannerUrl       String?
  socialInstagram String?
  socialFacebook  String?
  socialPinterest String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  products     Product[]
  followers    Follow[]
  reviews      Review[]
  reels        SellerReel[]
  storyBlocks  SellerStoryBlock[]
  shareEvents  ShareEvent[]
}

model Follow {
  id         String         @id @default(uuid()) @db.Uuid
  followerId String         @db.Uuid
  artisanId  String         @db.Uuid
  follower   User           @relation(fields: [followerId], references: [id])
  artisan    ArtisanProfile @relation(fields: [artisanId], references: [id])
  createdAt  DateTime       @default(now())

  @@unique([followerId, artisanId])
}

model Product {
  id          String         @id @default(uuid()) @db.Uuid
  artisanId   String         @db.Uuid
  artisan     ArtisanProfile @relation(fields: [artisanId], references: [id])
  title       String
  slug        String?        @unique
  description String
  price       Decimal        @db.Decimal(10, 2)
  currency    String         @default("INR")
  imageUrl    String?
  images      String[]
  stock       Int            @default(0)
  category    String
  tags        String[]
  isActive    Boolean        @default(true)
  isPublished Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  cartItems  CartItem[]
  wishlisted Wishlist[]
  reviews    Review[]
}

model Cart {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id        String  @id @default(uuid()) @db.Uuid
  cartId    String  @db.Uuid
  productId String  @db.Uuid
  cart      Cart    @relation(fields: [cartId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@unique([cartId, productId])
}

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model NewsletterSubscriber {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  subscribedAt DateTime @default(now())
}

model Review {
  id                 String         @id @default(uuid()) @db.Uuid
  artisanId          String         @db.Uuid
  artisan            ArtisanProfile @relation(fields: [artisanId], references: [id])
  reviewerId         String         @db.Uuid
  reviewer           User           @relation(fields: [reviewerId], references: [id])
  productId          String?        @db.Uuid
  product            Product?       @relation(fields: [productId], references: [id])
  rating             Int
  title              String?
  body               String?
  helpfulCount       Int            @default(0)
  isReported         Boolean        @default(false)
  isVerifiedPurchase Boolean        @default(false)
  createdAt          DateTime       @default(now())

  helpfulVotes ReviewHelpfulVote[]
  reports      ReviewReport[]
}

model ReviewHelpfulVote {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @db.Uuid
  review    Review   @relation(fields: [reviewId], references: [id])
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])

  @@unique([reviewId, userId])
}

model ReviewReport {
  id         String   @id @default(uuid()) @db.Uuid
  reviewId   String   @db.Uuid
  review     Review   @relation(fields: [reviewId], references: [id])
  reporterId String   @db.Uuid
  reporter   User     @relation(fields: [reporterId], references: [id])
  reason     String?
  createdAt  DateTime @default(now())

  @@unique([reviewId, reporterId])
}

model SellerReel {
  id           String         @id @default(uuid()) @db.Uuid
  artisanId    String         @db.Uuid
  artisan      ArtisanProfile @relation(fields: [artisanId], references: [id])
  title        String?
  description  String?
  videoUrl     String
  thumbnailUrl String?
  durationSec  Int?
  viewCount    Int            @default(0)
  likeCount    Int            @default(0)
  isPublished  Boolean        @default(false)
  createdAt    DateTime       @default(now())
}

model SellerStoryBlock {
  id        String         @id @default(uuid()) @db.Uuid
  artisanId String         @db.Uuid
  artisan   ArtisanProfile @relation(fields: [artisanId], references: [id])
  blockType StoryBlockType
  sortOrder Int?
  title     String?
  content   String?
  icon      String?
  imageUrl  String?
  createdAt DateTime       @default(now())
}

model ShareEvent {
  id        String         @id @default(uuid()) @db.Uuid
  artisanId String         @db.Uuid
  artisan   ArtisanProfile @relation(fields: [artisanId], references: [id])
  sharerId  String?        @db.Uuid
  sharer    User?          @relation(fields: [sharerId], references: [id])
  platform  String
  createdAt DateTime       @default(now())
}

model HeroSlide {
  id           String   @id @default(uuid()) @db.Uuid
  imageUrl     String
  altText      String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
